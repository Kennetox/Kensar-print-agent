{
  "name": "kensar-print-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Local print agent for SATO Easy Print",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "install:win": "scripts\\\\windows-install.bat",
    "start:win": "scripts\\\\windows-run.bat",
    "build:win": "pkg server.js --targets node18-win-x64 --output dist/KensarPrintAgent.exe"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  }
}
